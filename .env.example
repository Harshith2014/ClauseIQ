# Copy this to .env and fill in your values
# No paid services are required — all fields have safe defaults

# ── LLM backend ──────────────────────────────────────────────────────────────
# Option A: Groq (cloud, free tier — set this for Streamlit Community Cloud)
# Get your key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Option B: Ollama (local dev — used automatically when GROQ_API_KEY is blank)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LangSmith (free tier tracing — optional)
# Get your key at: https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=rag-legal-qa
LANGCHAIN_TRACING_V2=false

# Embedding model (no API key needed — downloads from HuggingFace)
EMBED_MODEL=BAAI/bge-small-en-v1.5
